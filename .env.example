# AI Provider Timeout (ms, default: 60000)
AI_PROVIDER_TIMEOUT_MS=60000

# Rate Limit Configuration
RATE_LIMIT_GENERATE=10
RATE_LIMIT_WINDOW_MS=60000

# 유저가 API Key를 입력하지 않았을 때 .env 키를 사용 여부 체크
USE_ENV_API_KEYS=false #  false (default) | true

# AI Provider API Keys (USE_ENV_API_KEYS=true일 때 유저가 입력하지 않으면 사용)
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
